KAFKA_BROKERS=localhost:9092

# Redis Sink
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=ticker
REDIS_KEY_TTL=60
KAFKA_TOPICS=binance-futures-ticker,binance-spot-ticker,bybit-futures-ticker,bybit-spot-ticker,hyperliquid-futures-ticker

# Arbitrage Detector
ARBITRAGE_THRESHOLD=0.2
STALENESS_SECONDS=5

# Flink Spread Analytics
FLINK_INPUT_TOPICS=binance-futures-ticker,bybit-futures-ticker
FLINK_OUTPUT_TOPIC=spread-analytics
SPREAD_WINDOW_SECONDS=300
FLINK_PARALLELISM=1

# Snowflake Sink
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_service_user
SNOWFLAKE_PRIVATE_KEY_PATH=./snowflake_rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_DATABASE=CRYPTO_DATA
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_TABLE=SPREAD_ANALYTICS
SNOWFLAKE_KAFKA_TOPIC=spread-analytics
SNOWFLAKE_BATCH_SIZE=1000
SNOWFLAKE_FLUSH_INTERVAL=10
